<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <title>Blog Beauty</title>
</head>
<body>
    <div class="creation home card">
        <h1>
            Create a New Blog Today!
        </h1>
        <form action="/blogs" method="get">
            <button type="submit">
                Create
            </button>
        </form>
    </div>
    <br><br>
    <div class="blog card">
        <h2>
            Your Past Entries
        </h2>

        <%for(let i =0; i<bloggs.length; i++){%>
            <a href="/edit/<%=i%>"><h2><%=bloggs[i].title%></h2></a>
            <p><%=bloggs[i].content%></p>
        <%}%>
        <br><br>
    </div>
    <div class="deletion card">
        <h2>Wanna Delete some Entries??</h2>
        <form action="/deletion" method="get">
            <button type="submit">
                Yeaaa!!
            </button>
        </form>
    </div>
</body>
</html>